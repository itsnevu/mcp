{
  "mcpServers": {
    "boar-basic": {
      "type": "http",
      "url": "https://mcp.boar.network/basic"
    },
    "boar-advanced": {
      "type": "http",
      "url": "https://mcp.boar.network/advanced"
    },
    "blockscout": {
      "url": "https://blockscout.mcp.junct.dev/mcp",
      "transport": "streamable-http"
    },
    "boo-crypto": {
      "command": "npx",
      "args": ["-y", "boo-crypto-mcp@1.0.1"]
    },
    "fuse": {
      "url": "https://mcp.fuse.io/mcp"
    },
    "whale-intel": {
      "url": "https://mcp.swisswhaleintelligence.com/mcp"
    },
    "etherscan": {
      "command": "npx",
      "args": ["-y", "etherscan-mcp-server@1.0.1"],
      "envFrom": ["ETHERSCAN_API_KEY"]
    },
    "hoodpocket": {
      "disabled": true,
      "command": "npx",
      "args": ["-y", "hoodpocket@0.4.0"]
    },
    "hooddomains": {
      "command": "npx",
      "args": ["-y", "hooddomains-mcp@0.1.1"],
      "env": {
        "HOOD_RPC_URL": "https://rpc.mainnet.chain.robinhood.com"
      }
    },
    "dexscreener": {
      "command": "npx",
      "args": ["-y", "@iflow-mcp/janswist-dexscreener-mcp-server@1.0.0"]
    }
  }
}
